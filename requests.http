### ==========================================
### AUTH
### ==========================================

### Register User 1

POST http://localhost:3000/auth/register
Content-Type: application/json

{
  "username": "ivan",
  "password": "123456",
  "name": "Іван"
}

###

### Register User 2

POST http://localhost:3000/auth/register
Content-Type: application/json

{
  "username": "petro",
  "password": "123456",
  "name": "Петро"
}

###

### Login User 1

# @name loginUser1

POST http://localhost:3000/auth/login
Content-Type: application/json

{
  "username": "ivan",
  "password": "123456"
}

###

@accessToken = {{loginUser1.response.body.accessToken}}
@refreshToken = {{loginUser1.response.body.refreshToken}}

### Current User

GET http://localhost:3000/auth/me
Authorization: Bearer {{accessToken}}

###

### Refresh Token

POST http://localhost:3000/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

###

### Logout

POST http://localhost:3000/auth/logout

###

### Invalid Login

POST http://localhost:3000/auth/login
Content-Type: application/json

{
  "username": "ivan",
  "password": "wrong_password"
}

