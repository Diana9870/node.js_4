### ==========================================
### ANNOUNCEMENTS
### ==========================================

### Get All

GET http://localhost:3000/announcements

###

### Get By Id

GET http://localhost:3000/announcements/1

###

### Create Announcement WITHOUT PHOTO

POST http://localhost:3000/announcements
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="title"

iPhone 14
--boundary
Content-Disposition: form-data; name="description"

Новий смартфон
--boundary
Content-Disposition: form-data; name="price"

25000
--boundary
Content-Disposition: form-data; name="category"

sale
--boundary
Content-Disposition: form-data; name="contactInfo"

+380991112233
--boundary--

###

### Create Announcement WITH PHOTO

POST http://localhost:3000/announcements
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="title"

MacBook Air
--boundary
Content-Disposition: form-data; name="description"

Новий ноутбук
--boundary
Content-Disposition: form-data; name="price"

45000
--boundary
Content-Disposition: form-data; name="category"

sale
--boundary
Content-Disposition: form-data; name="contactInfo"

+380991112233
--boundary
Content-Disposition: form-data; name="image"; filename="photo.jpg"
Content-Type: image/jpeg

< ./photo.jpg
--boundary--

###

### Update Announcement WITH PHOTO

PATCH http://localhost:3000/announcements/1
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="price"

23000
--boundary
Content-Disposition: form-data; name="image"; filename="photo.jpg"
Content-Type: image/jpeg

< ./photo.jpg
--boundary--

###

### Delete Own Announcement

DELETE http://localhost:3000/announcements/1
Authorization: Bearer {{accessToken}}

### ==========================================
### 401 TESTS
### ==========================================

POST http://localhost:3000/announcements
Content-Type: application/json

{
  "title": "Unauthorized",
  "description": "Should fail",
  "price": 100,
  "category": "sale",
  "contactInfo": "000000000"
}

###

PATCH http://localhost:3000/announcements/1
Content-Type: application/json

{
  "price": 1
}

###

DELETE http://localhost:3000/announcements/1

### ==========================================
### 403 TESTS
### ==========================================

### Login User 2

# @name loginUser2

POST http://localhost:3000/auth/login
Content-Type: application/json

{
  "username": "petro",
  "password": "123456"
}

###

@user2AccessToken = {{loginUser2.response.body.accessToken}}

### Update чужого оголошення

PATCH http://localhost:3000/announcements/1
Authorization: Bearer {{user2AccessToken}}
Content-Type: application/json

{
  "price": 999
}

###

### Delete чужого оголошення

DELETE http://localhost:3000/announcements/1
Authorization: Bearer {{user2AccessToken}}